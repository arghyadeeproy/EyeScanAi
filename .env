# ─────────────────────────────────────────────
# EyeScan AI — Environment Variables
# ─────────────────────────────────────────────
# All variables prefixed with EXPO_PUBLIC_ are
# bundled into the JS bundle at build time and
# accessible via process.env.EXPO_PUBLIC_*
#
# ➤  Android Emulator  → 10.0.2.2
# ➤  iOS Simulator     → localhost  or 127.0.0.1
# ➤  Physical Device   → LAN IP, e.g. 192.168.x.x
# ─────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://192.168.31.196:8000
